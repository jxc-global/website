---
const agents = ["Arty", "Flyn", "Ilya"];
const capabilities = [
  "Agent team design",
  "Workflow automation",
  "Operational copilots",
  "Tool and system integration"
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="JXC builds and operates AI agent teams for real business workflows."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>JXC</title>
    <style>
      :root {
        color-scheme: light;
        --black: #000;
        --white: #fff;
        --line: #111;
        --muted: #555;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background: var(--white);
        color: var(--black);
      }

      body {
        margin: 0;
        min-width: 320px;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .shell {
        min-height: 100vh;
        display: grid;
        grid-template-rows: auto 1fr auto;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 24px;
        padding: 20px clamp(18px, 4vw, 56px);
        border-bottom: 2px solid var(--black);
      }

      .brand {
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 0;
      }

      nav {
        display: flex;
        gap: clamp(12px, 2vw, 28px);
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
      }

      main {
        display: grid;
      }

      .hero {
        min-height: calc(100vh - 70px);
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
        border-bottom: 2px solid var(--black);
      }

      .hero-copy {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        gap: 40px;
        padding: clamp(32px, 6vw, 88px) clamp(18px, 5vw, 72px);
      }

      h1 {
        margin: 0;
        max-width: 940px;
        font-size: clamp(64px, 12vw, 178px);
        line-height: 0.84;
        letter-spacing: 0;
        text-transform: uppercase;
      }

      .dek {
        max-width: 680px;
        margin: 0;
        font-size: clamp(22px, 3vw, 42px);
        line-height: 1.05;
        font-weight: 750;
      }

      .hero-panel {
        border-left: 2px solid var(--black);
        display: grid;
        grid-template-rows: 1fr auto;
      }

      .signal {
        min-height: 360px;
        background:
          linear-gradient(90deg, transparent 47%, var(--black) 47%, var(--black) 53%, transparent 53%),
          linear-gradient(0deg, transparent 47%, var(--black) 47%, var(--black) 53%, transparent 53%);
        background-size: 48px 48px;
      }

      .fact {
        border-top: 2px solid var(--black);
        padding: 24px;
        font-size: 18px;
        line-height: 1.2;
        font-weight: 700;
      }

      section {
        padding: clamp(42px, 7vw, 92px) clamp(18px, 5vw, 72px);
        border-bottom: 2px solid var(--black);
      }

      .section-grid {
        display: grid;
        grid-template-columns: 260px minmax(0, 1fr);
        gap: clamp(28px, 6vw, 96px);
      }

      h2 {
        margin: 0;
        font-size: 14px;
        font-weight: 850;
        text-transform: uppercase;
      }

      .large {
        max-width: 980px;
        margin: 0;
        font-size: clamp(30px, 5vw, 72px);
        line-height: 0.98;
        font-weight: 800;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        border-top: 2px solid var(--black);
        border-left: 2px solid var(--black);
      }

      .cell {
        min-height: 190px;
        padding: 20px;
        border-right: 2px solid var(--black);
        border-bottom: 2px solid var(--black);
        display: flex;
        align-items: flex-end;
        font-size: 24px;
        line-height: 1;
        font-weight: 800;
      }

      .agents {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        border-top: 2px solid var(--black);
      }

      .agent {
        padding: 24px 0;
        border-bottom: 2px solid var(--black);
        font-size: clamp(32px, 5vw, 74px);
        line-height: 0.95;
        font-weight: 850;
        text-transform: uppercase;
      }

      .agent + .agent {
        border-left: 2px solid var(--black);
        padding-left: 24px;
      }

      .contact {
        display: flex;
        justify-content: space-between;
        gap: 24px;
        align-items: flex-end;
      }

      .contact a {
        display: inline-flex;
        min-height: 56px;
        align-items: center;
        border: 2px solid var(--black);
        padding: 0 18px;
        font-weight: 850;
        text-transform: uppercase;
      }

      footer {
        padding: 18px clamp(18px, 4vw, 56px);
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
      }

      @media (max-width: 860px) {
        header,
        nav,
        .contact {
          align-items: flex-start;
          flex-direction: column;
        }

        .hero,
        .section-grid,
        .grid,
        .agents {
          grid-template-columns: 1fr;
        }

        .hero {
          min-height: auto;
        }

        .hero-panel,
        .agent + .agent {
          border-left: 0;
        }

        .hero-panel {
          border-top: 2px solid var(--black);
        }

        .signal {
          min-height: 220px;
        }

        .agent + .agent {
          padding-left: 0;
        }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <header>
        <a class="brand" href="/">JXC</a>
        <nav aria-label="Primary">
          <a href="#work">Work</a>
          <a href="#agents">Agents</a>
          <a href="#contact">Contact</a>
        </nav>
      </header>

      <main>
        <section class="hero" aria-labelledby="title">
          <div class="hero-copy">
            <h1 id="title">JXC</h1>
            <p class="dek">
              We build and operate AI agent teams for real business workflows.
            </p>
          </div>
          <div class="hero-panel" aria-hidden="true">
            <div class="signal"></div>
            <div class="fact">Practical automation. Clear ownership. Live systems.</div>
          </div>
        </section>

        <section id="work">
          <div class="section-grid">
            <h2>What We Do</h2>
            <p class="large">
              JXC turns repeatable operational work into managed agent systems:
              researched, integrated, monitored, and improved in production.
            </p>
          </div>
        </section>

        <section aria-label="Capabilities">
          <div class="grid">
            {capabilities.map((item) => <div class="cell">{item}</div>)}
          </div>
        </section>

        <section id="agents">
          <div class="section-grid">
            <h2>Agent Team</h2>
            <div class="agents">
              {agents.map((agent) => <div class="agent">{agent}</div>)}
            </div>
          </div>
        </section>

        <section>
          <div class="section-grid">
            <h2>How We Work</h2>
            <p class="large">
              Start narrow. Ship working systems. Measure reality. Expand only
              where the work earns it.
            </p>
          </div>
        </section>

        <section id="contact">
          <div class="contact">
            <p class="large">Build the agent layer your company can actually run.</p>
            <a href="mailto:hello@jxc.global">hello@jxc.global</a>
          </div>
        </section>
      </main>

      <footer>JXC Global</footer>
    </div>
  </body>
</html>
